{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "landingPage": "/wp-admin/",
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "elementor"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installTheme",
      "themeData": {
        "resource": "wordpress.org/themes",
        "slug": "hello-elementor"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "activatePlugin",
      "pluginPath": "bolly-3d-bottle/bolly-3d-bottle.php"
    }
  ]
}
